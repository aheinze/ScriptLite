{
    "name": "scriptlite/engine",
    "description": "A JavaScript (ES5/ES6 subset) bytecode-compiled interpreter written in PHP 8.3+",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ScriptLite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScriptLite\\Tests\\": "tests/"
        }
    }
}
