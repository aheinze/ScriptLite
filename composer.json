{
    "name": "aheinze/scriptlite",
    "version": "0.1.0",
    "description": "An ECMAScript (ES5/ES6 subset) bytecode-compiled interpreter",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ScriptLite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScriptLite\\Tests\\": "tests/"
        }
    }
}
